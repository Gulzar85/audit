# Environment Variables Configuration
# Copy this file to .env and fill in the actual values
# NEVER commit the actual .env file to version control!

# ===== DEVELOPMENT =====
# SECRET_KEY should be a long random string
# Generate new one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-change-in-production

# Debug mode (True for development, False for production)
DEBUG=False

# Allowed hosts for production (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database URL (SQLite for dev, PostgreSQL/MySQL for production)
DATABASE_URL=sqlite:///db.sqlite3

# ===== EMAIL CONFIGURATION =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=audit@mcdonalds.pk

# ===== PRODUCTION SECURITY SETTINGS =====
# These are only used when DEBUG=False

# HTTPS/TLS Settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Cookie Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=True

# Admin URL Protection (CRITICAL: Change from default /admin/)
# Generate a random token: python -c "import secrets; print(secrets.token_hex(16))"
ADMIN_TOKEN=change-this-to-random-token-in-production
ADMIN_URL=secret-admin-panel-{{ ADMIN_TOKEN }}/

# ===== SECURITY RECOMMENDATIONS =====
# 1. Always use HTTPS in production (SECURE_SSL_REDIRECT=True)
# 2. Generate new SECRET_KEY for production
# 3. Use strong, unique ADMIN_TOKEN (at least 32 characters)
# 4. Use PostgreSQL instead of SQLite for production
# 5. Keep all credentials in environment variables, never in code
# 6. Rotate credentials regularly
# 7. Use a secrets management system (AWS Secrets Manager, HashiCorp Vault, etc.)
# 8. Monitor security logs regularly
# 9. Keep Django and all packages updated
# 10. Enable 2FA for all admin accounts
